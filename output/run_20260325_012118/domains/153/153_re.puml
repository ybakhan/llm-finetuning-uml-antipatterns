@startuml
left to right direction

actor "API Developer" as Dev
actor "API Consumer" as Consumer
actor "Portal Admin" as Admin

rectangle "API Management Portal" {
  usecase "Register API" as UC1
  usecase "Browse API Catalog" as UC3
  usecase "Subscribe to API" as UC4
  usecase "Generate API Key" as UC5
  usecase "View API Analytics" as UC6
  usecase "Monitor API Health" as UC7
  usecase "Manage Rate Limits" as UC8
  usecase "Configure API Gateway" as UC9
  usecase "Manage User Accounts" as UC10
  usecase "Review API Documentation" as UC11
  usecase "Publish API Documentation" as UC12
  usecase "Revoke API Key" as UC13
  usecase "Test API Endpoint" as UC14
}

Dev -- UC1
Dev -- UC6
Dev -- UC12
Dev -- UC14

Consumer -- UC3
Consumer -- UC4
Consumer -- UC5
Consumer -- UC11

Admin -- UC7
Admin -- UC8
Admin -- UC9
Admin -- UC10
Admin -- UC13
@enduml