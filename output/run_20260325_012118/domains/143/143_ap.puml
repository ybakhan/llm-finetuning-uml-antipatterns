@startuml
left to right direction

actor "Tournament Organizer" as Organizer
actor "Player" as Player
actor "Spectator" as Spectator
actor "Caster" as Caster
actor "Admin" as Admin

rectangle "Esports Tournament Platform" {
  usecase "Create Tournament" as UC1
  usecase "Validate Tournament Rules" as UC2
  usecase "Register for Tournament" as UC3
  usecase "Verify Player Eligibility" as UC4
  usecase "Submit Match Result" as UC5
  usecase "View Live Bracket" as UC6
  usecase "Stream Match" as UC7
  usecase "Provide Commentary" as UC8
  usecase "Manage Player Profiles" as UC9
  usecase "Ban Player" as UC10
  usecase "View Tournament Schedule" as UC11
  usecase "Distribute Prizes" as UC12
  usecase "Appeal Match Result" as UC13
  usecase "Generate Tournament Statistics" as UC14
}

Organizer -- UC1
UC1 ..> UC2 : <<include>>
Organizer -- UC5
Organizer -- UC12
Organizer -- UC11

Player -- UC3
UC3 ..> UC4 : <<include>>
Player -- UC5
Player -- UC13
Player -- UC9

Spectator -- UC6
Spectator -- UC7
Spectator -- UC11

Caster -- UC8
Caster -- UC7

Admin -- UC10
Admin -- UC14

UC13 ..> UC5 : <<extend>>
@enduml