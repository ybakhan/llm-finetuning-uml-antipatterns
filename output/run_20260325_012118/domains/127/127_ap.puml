@startuml
left to right direction

actor "Applicant" as A1
actor "Registrar" as A2

rectangle "Company Registration System" {
  usecase "Register Company" as UC1
  usecase "Verify Company Name" as UC2
  usecase "Review Application" as UC3
  usecase "Issue Certificate" as UC4
  usecase "Search Company Records" as UC5
  usecase "Pay Registration Fee" as UC6
}

A1 -- UC1
A1 -- UC5
A1 -- UC6
A2 -- UC3
A2 -- UC4

UC1 ..> UC2 : <<include>>
@enduml