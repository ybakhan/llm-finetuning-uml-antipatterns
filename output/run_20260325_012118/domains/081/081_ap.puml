@startuml
left to right direction

actor "Rider" as Rider
actor "Station Technician" as Tech
actor "System Administrator" as Admin

rectangle "Bike Sharing System" {
  usecase "Register Account" as UC1
  usecase "Validate Email Format" as UC1a
  usecase "Save User to Database" as UC1b
  usecase "Rent Bike" as UC2
  usecase "Return Bike" as UC3
  usecase "Report Bike Issue" as UC4
  usecase "View Ride History" as UC5
  usecase "Process Payment" as UC6
  usecase "Validate Payment Details" as UC6a
  usecase "Charge Payment Method" as UC6b
  usecase "Perform Bike Maintenance" as UC7
  usecase "Inspect Station" as UC8
  usecase "Manage Stations" as UC9
  usecase "View System Analytics" as UC10
  usecase "Manage Pricing Plans" as UC11
}

Rider -- UC1
Rider -- UC2
Rider -- UC3
Rider -- UC4
Rider -- UC5
Rider -- UC6

UC1 ..> UC1a : <<include>>
UC1 ..> UC1b : <<include>>

UC6 ..> UC6a : <<include>>
UC6 ..> UC6b : <<include>>

Tech -- UC7
Tech -- UC8

Admin -- UC9
Admin -- UC10
Admin -- UC11
@enduml