@startuml
left to right direction

actor "Warehouse Manager" as WM
actor "Purchasing Officer" as PO
actor "Sales Staff" as SS
actor "Inventory Auditor" as IA
actor "System Administrator" as SA

rectangle "Inventory Management System" {
  usecase "Receive Shipment" as UC1
  usecase "Validate Shipment Contents" as UC2
  usecase "Update Stock Quantities" as UC3
  usecase "Create Purchase Order" as UC4
  usecase "Check Reorder Levels" as UC5
  usecase "Generate Supplier Order" as UC6
  usecase "Process Sales Order" as UC7
  usecase "View Stock Levels" as UC8
  usecase "Conduct Stock Audit" as UC9
  usecase "Adjust Inventory Discrepancies" as UC10
  usecase "Manage Product Catalog" as UC11
  usecase "Configure Warehouse Locations" as UC12
  usecase "Generate Inventory Report" as UC13
  usecase "Transfer Stock Between Warehouses" as UC14
}

WM -- UC1
UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<include>>
PO -- UC4
UC4 ..> UC5 : <<include>>
UC4 ..> UC6 : <<include>>
SS -- UC7
SS -- UC8
IA -- UC9
IA -- UC10
SA -- UC11
SA -- UC12
WM -- UC13
WM -- UC14
@enduml