@startuml
left to right direction

actor "User" as U1

rectangle "Social Media Platform" {
  usecase "Create Post" as UC1
  usecase "View Feed" as UC2
  usecase "Send Message" as UC3
  usecase "Validate Post Content" as UC4
  usecase "Save Post to Database" as UC5
}

U1 -- UC1
U1 -- UC2
U1 -- UC3

UC1 ..> UC4 : <<include>>
UC1 ..> UC5 : <<include>>
@enduml