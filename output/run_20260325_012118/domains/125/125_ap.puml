@startuml
left to right direction

actor "Loan Officer" as LO
actor "Borrower" as BO
actor "Branch Manager" as BM
actor "System Administrator" as SA

rectangle "Microfinance System" {
  usecase "Register Borrower" as UC1
  usecase "Apply for Loan" as UC2
  usecase "Evaluate Creditworthiness" as UC3
  usecase "Approve Loan" as UC4
  usecase "Disburse Loan" as UC5
  usecase "Record Repayment" as UC6
  usecase "View Loan Status" as UC7
  usecase "Generate Portfolio Report" as UC8
  usecase "Manage Savings Account" as UC9
  usecase "Send Payment Reminder" as UC10
  usecase "Handle Loan Default" as UC11
  usecase "Configure System Parameters" as UC12
  usecase "Validate Borrower Identity" as UC13
  usecase "Calculate Interest" as UC14
  usecase "Check Repayment Schedule" as UC15
}

LO -- UC1
LO -- UC2
LO -- UC3
LO -- UC6
LO -- UC10
BO -- UC2
BO -- UC7
BO -- UC9
BM -- UC4
BM -- UC5
BM -- UC8
BM -- UC11
SA -- UC12

UC1 ..> UC13 : <<include>>
UC6 ..> UC14 : <<include>>
UC6 ..> UC15 : <<include>>
@enduml