@startuml
left to right direction

actor Seller
actor Buyer
actor Admin

rectangle "Second-Hand Marketplace" {
  usecase "List Item for Sale" as UC1
  usecase "Upload Photos" as UC2
  usecase "Set Pricing" as UC3
  usecase "Browse Listings" as UC4
  usecase "Search Items" as UC5
  usecase "Purchase Item" as UC6
  usecase "Validate Payment Details" as UC7
  usecase "Send Message to Seller" as UC8
  usecase "Leave Review" as UC9
  usecase "Report Listing" as UC10
  usecase "Manage Categories" as UC11
  usecase "Remove Fraudulent Listing" as UC12
  usecase "Track Order" as UC13
  usecase "Make Offer" as UC14
  usecase "Save to Wishlist" as UC15
}

Seller -- UC1
UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<include>>
Buyer -- UC4
Buyer -- UC5
Buyer -- UC6
UC6 ..> UC7 : <<include>>
Buyer -- UC8
Buyer -- UC9
Buyer -- UC10
Admin -- UC11
Admin -- UC12
Buyer -- UC13
Buyer -- UC14
Buyer -- UC15
@enduml