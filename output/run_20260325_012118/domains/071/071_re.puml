@startuml
left to right direction

actor "Property Manager" as PM
actor "Tenant" as T
actor "Maintenance Staff" as MS
actor "Owner" as OW

rectangle "Property Management System" {
  usecase "List Property" as UC1
  usecase "Sign Lease Agreement" as UC2
  usecase "Collect Rent" as UC3
  usecase "Submit Maintenance Request" as UC4
  usecase "Assign Maintenance Task" as UC5
  usecase "Complete Maintenance Task" as UC6
  usecase "View Property Portfolio" as UC7
  usecase "Generate Financial Report" as UC8
  usecase "Screen Tenant Application" as UC9
  usecase "Schedule Property Inspection" as UC10
  usecase "Send Lease Renewal Notice" as UC11
  usecase "Track Expenses" as UC12
}

PM -- UC1
PM -- UC2
PM -- UC3
PM -- UC5
PM -- UC9
PM -- UC10
PM -- UC11
PM -- UC12

T -- UC2
T -- UC4

MS -- UC6

OW -- UC7
OW -- UC8
@enduml