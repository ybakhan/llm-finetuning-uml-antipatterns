@startuml
left to right direction

actor "Loan Applicant" as Applicant
actor "Loan Officer" as Officer

rectangle "Loan Approval System" {
  usecase "Submit Loan Application" as UC1
  usecase "Review Loan Application" as UC2
  usecase "Approve or Reject Loan" as UC3
  usecase "Check Credit Score" as UC4
  usecase "View Loan Status" as UC5
  usecase "Generate Loan Agreement" as UC6
}

Applicant -- UC1
Applicant -- UC5
Officer -- UC2
Officer -- UC3
Officer -- UC6

UC2 ..> UC4 : <<include>>
@enduml