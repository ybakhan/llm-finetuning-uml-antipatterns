@startuml
left to right direction

actor "Customer" as Customer
actor "Technician" as Technician

rectangle "Vending Machine Management System" {
  usecase "Purchase Product" as UC1
  usecase "Validate Payment" as UC2
  usecase "Dispense Item" as UC3
  usecase "Restock Machine" as UC4
  usecase "View Inventory" as UC5
}

Customer -- UC1
Technician -- UC4
Technician -- UC5
UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<include>>
@enduml