@startuml
left to right direction

actor "Customer" as Customer
actor "Technician" as Technician

rectangle "Water Utility Management System" {
  usecase "Pay Water Bill" as UC1
  usecase "Report Leak" as UC2
  usecase "Perform Maintenance" as UC3
  usecase "View Usage History" as UC4
  usecase "Submit Meter Reading" as UC5
  usecase "Validate Meter Data" as UC6
}

Customer -- UC1
Customer -- UC2
Customer -- UC4
Technician -- UC3
Technician -- UC5
UC5 ..> UC6 : <<include>>
@enduml