@startuml
left to right direction

actor "Tourist" as Tourist
actor "Tour Guide" as Guide

rectangle "City Tour Guide App" {
  usecase "Browse Tours" as UC1
  usecase "Book Tour" as UC2
  usecase "Rate Tour" as UC3
  usecase "Create Tour Listing" as UC4
  usecase "View Tour Details" as UC5
  usecase "Load Map Data" as UC6
}

Tourist -- UC1
Tourist -- UC2
Tourist -- UC3
Guide -- UC4
UC1 .> UC5 : <<include>>
UC5 .> UC6 : <<include>>
@enduml