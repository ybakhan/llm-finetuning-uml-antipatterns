@startuml
left to right direction

actor "Shipper" as Shipper
actor "Carrier" as Carrier
actor "Warehouse Manager" as WM
actor "Customer" as Customer
actor "System Administrator" as Admin

rectangle "Freight Tracking System" {
  usecase "Create Shipment" as UC1
  usecase "Update Shipment Status" as UC2
  usecase "Track Shipment" as UC3
  usecase "Assign Carrier" as UC4
  usecase "Register Freight Arrival" as UC5
  usecase "Manage Routes" as UC6
  usecase "Generate Shipment Report" as UC7
  usecase "Request Delivery Estimate" as UC8
  usecase "File Damage Claim" as UC9
  usecase "Cancel Shipment" as UC10
  usecase "Manage User Accounts" as UC11
  usecase "Schedule Pickup" as UC13
  usecase "View Shipment History" as UC14
}

Shipper -- UC1
Shipper -- UC4
Shipper -- UC10
Shipper -- UC13
Carrier -- UC2
Carrier -- UC5
WM -- UC5
WM -- UC7
Customer -- UC3
Customer -- UC8
Customer -- UC9
Customer -- UC14
Admin -- UC6
Admin -- UC11
@enduml