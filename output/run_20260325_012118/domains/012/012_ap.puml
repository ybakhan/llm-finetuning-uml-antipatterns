@startuml
left to right direction

actor "Viewer" as Viewer
actor "Content Creator" as Creator

rectangle "Video Streaming Platform" {
  usecase "Watch Video" as UC1
  usecase "Search Content" as UC2
  usecase "Upload Video" as UC3
  usecase "Manage Subscription" as UC4
  usecase "Load Video Player" as UC5
  usecase "Buffer Stream Data" as UC6
}

Viewer -- UC1
Viewer -- UC2
Viewer -- UC4
Creator -- UC3

UC1 ..> UC5 : <<include>>
UC1 ..> UC6 : <<include>>
@enduml