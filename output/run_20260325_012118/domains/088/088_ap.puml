@startuml
left to right direction

actor "Shopper" as Shopper
actor "Sale Admin" as Admin

rectangle "Flash Sale Platform" {
  usecase "Browse Active Sales" as UC1
  usecase "Purchase Deal" as UC2
  usecase "Validate Payment Details" as UC3
  usecase "Create Flash Sale" as UC4
  usecase "View Sales Analytics" as UC5
}

Shopper -- UC1
Shopper -- UC2
UC2 ..> UC3 : <<include>>
Admin -- UC4
Admin -- UC5

@enduml