@startuml
left to right direction

actor "Customer" as Customer
actor "Rental Agent" as Agent

rectangle "Car Rental System" {
  usecase "Browse Available Cars" as UC1
  usecase "Reserve Car" as UC2
  usecase "Return Car" as UC3
  usecase "Validate Driver License" as UC4
  usecase "Manage Fleet" as UC5
}

Customer -- UC1
Customer -- UC2
Customer -- UC3
Agent -- UC5
UC2 ..> UC4 : <<include>>
@enduml