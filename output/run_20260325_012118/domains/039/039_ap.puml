@startuml
left to right direction

actor "Teacher" as Teacher
actor "Student" as Student
actor "Administrator" as Admin
actor "Parent" as Parent

rectangle "School Administration System" {
  usecase "Record Attendance" as UC1
  usecase "Submit Grades" as UC2
  usecase "Validate Grade Scale" as UC3
  usecase "View Report Card" as UC4
  usecase "Enroll Student" as UC5
  usecase "Manage Class Schedule" as UC6
  usecase "Request Transcript" as UC7
  usecase "Send Notification to Parents" as UC8
  usecase "Register for Course" as UC9
  usecase "View Attendance Record" as UC10
  usecase "Generate Annual Report" as UC11
  usecase "Update Student Profile" as UC12
  usecase "Assign Teacher to Class" as UC13
  usecase "View Class Schedule" as UC14
}

Teacher -- UC1
Teacher -- UC2
UC2 ..> UC3 : <<include>>
Student -- UC4
Student -- UC9
Student -- UC7
Admin -- UC5
Admin -- UC6
Admin -- UC11
Admin -- UC13
Admin -- UC8
Admin -- UC12
Parent -- UC10
Parent -- UC4
Teacher -- UC14
Student -- UC14
}
@enduml