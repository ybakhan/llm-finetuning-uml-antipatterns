@startuml
left to right direction

actor "License Administrator" as Admin
actor "End User" as EndUser
actor "Compliance Auditor" as Auditor

rectangle "Software License Management System" {
  usecase "Register New License" as UC1
  usecase "Assign License to User" as UC2
  usecase "Revoke License" as UC3
  usecase "View License Dashboard" as UC4
  usecase "Request License" as UC5
  usecase "Generate Compliance Report" as UC6
  usecase "Conduct License Audit" as UC7
  usecase "Renew License" as UC8
  usecase "Manage Vendor Contracts" as UC9
  usecase "Track Software Usage" as UC10
  usecase "Validate License Key" as UC11
  usecase "Calculate Renewal Cost" as UC12
}

Admin -- UC1
Admin -- UC2
Admin -- UC3
Admin -- UC4
Admin -- UC8
Admin -- UC9
EndUser -- UC5
EndUser -- UC10
Auditor -- UC6
Auditor -- UC7

UC1 ..> UC11 : <<include>>
UC8 ..> UC12 : <<include>>
@enduml