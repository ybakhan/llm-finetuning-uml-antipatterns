@startuml
left to right direction

actor "HR Manager" as HRM
actor "Employee" as EMP
actor "Recruiter" as REC
actor "Payroll Officer" as PAY
actor "Department Head" as DH

rectangle "Human Resources System" {
  usecase "Post Job Opening" as UC1
  usecase "Screen Applications" as UC2
  usecase "Schedule Interview" as UC3
  usecase "Submit Leave Request" as UC4
  usecase "Approve Leave Request" as UC5
  usecase "View Pay Slip" as UC6
  usecase "Process Monthly Payroll" as UC7
  usecase "Conduct Performance Review" as UC9
  usecase "Update Employee Profile" as UC10
  usecase "Generate HR Report" as UC11
  usecase "Manage Benefits Enrollment" as UC12
  usecase "Onboard New Employee" as UC13
  usecase "Terminate Employee" as UC14
}

REC -- UC1
REC -- UC2
REC -- UC3
EMP -- UC4
EMP -- UC6
EMP -- UC10
HRM -- UC5
HRM -- UC9
HRM -- UC11
HRM -- UC13
HRM -- UC14
PAY -- UC7
DH -- UC9
DH -- UC12
@enduml