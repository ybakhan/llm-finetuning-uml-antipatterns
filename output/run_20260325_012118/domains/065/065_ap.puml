@startuml
left to right direction

actor "Member" as Member
actor "Moderator" as Moderator

rectangle "Forum and Discussion System" {
  usecase "Create Thread" as UC1
  usecase "Reply to Thread" as UC2
  usecase "Moderate Content" as UC3
  usecase "Search Forums" as UC4
  usecase "Validate Post Content" as UC5
}

Member -- UC1
Member -- UC2
Member -- UC4
Moderator -- UC3

UC1 ..> UC5 : <<include>>
@enduml