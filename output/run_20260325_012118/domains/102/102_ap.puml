@startuml
left to right direction

actor "Therapist" as Therapist
actor "Patient" as Patient

rectangle "Rehabilitation Centre System" {
  usecase "Schedule Session" as UC1
  usecase "Validate Therapist Availability" as UC2
  usecase "Record Progress" as UC3
  usecase "View Treatment Plan" as UC4
}

Therapist -- UC1
Therapist -- UC3
Patient -- UC4

UC1 ..> UC2 : <<include>>
@enduml