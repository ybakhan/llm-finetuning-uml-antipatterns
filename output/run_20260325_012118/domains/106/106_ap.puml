@startuml
left to right direction

actor "Learner" as Learner
actor "Instructor" as Instructor

rectangle "Language Learning App" {
  usecase "Take Vocabulary Quiz" as UC1
  usecase "Load Quiz Questions" as UC2
  usecase "Calculate Quiz Score" as UC3
  usecase "Practice Pronunciation" as UC4
  usecase "View Progress Report" as UC5
  usecase "Create Lesson Plan" as UC6
}

Learner -- UC1
Learner -- UC4
Learner -- UC5
Instructor -- UC6

UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<include>>
@enduml