@startuml
left to right direction

actor "Developer" as Dev
actor "Tester" as Tester
actor "Project Manager" as PM

rectangle "Software Bug Tracking System" {
  usecase "Report Bug" as UC1
  usecase "Validate Bug Fields" as UC2
  usecase "Assign Bug to Developer" as UC3
  usecase "Check Developer Availability" as UC4
  usecase "Update Bug Status" as UC5
  usecase "View Bug Dashboard" as UC6
  usecase "Search Bugs" as UC7
  usecase "Add Comment to Bug" as UC8
  usecase "Resolve Bug" as UC9
  usecase "Reopen Bug" as UC10
  usecase "Close Bug" as UC11
  usecase "Generate Bug Report" as UC12
  usecase "Export Report to PDF" as UC13
  usecase "Set Bug Priority" as UC14
  usecase "View Bug History" as UC15
}

Tester -- UC1
UC1 ..> UC2 : <<include>>
PM -- UC3
UC3 ..> UC4 : <<include>>
Dev -- UC5
PM -- UC6
Tester -- UC7
Dev -- UC8
Tester -- UC8
Dev -- UC9
Tester -- UC10
PM -- UC11
PM -- UC12
UC12 ..> UC13 : <<include>>
PM -- UC14
Dev -- UC15
Tester -- UC15
UC10 ..> UC1 : <<extend>>
}
@enduml