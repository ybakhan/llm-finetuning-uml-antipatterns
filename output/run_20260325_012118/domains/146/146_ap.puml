@startuml
left to right direction

actor "Member" as Member
actor "Instructor" as Instructor

rectangle "Yoga Class Booking System" {
  usecase "Browse Class Schedule" as UC1
  usecase "Book Class" as UC2
  usecase "Validate Membership" as UC3
  usecase "Cancel Booking" as UC4
  usecase "View Enrolled Students" as UC5
  usecase "Mark Attendance" as UC6
}

Member -- UC1
Member -- UC2
UC2 ..> UC3 : <<include>>
Member -- UC4
Instructor -- UC5
Instructor -- UC6
@enduml