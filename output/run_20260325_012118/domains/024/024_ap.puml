@startuml
left to right direction

actor "User" as User
actor "Fitness Coach" as Coach
actor "Admin" as Admin

rectangle "Fitness Tracking App" {
  usecase "Log Workout" as UC1
  usecase "View Workout History" as UC2
  usecase "Set Fitness Goal" as UC3
  usecase "Track Calories" as UC4
  usecase "View Progress Dashboard" as UC5
  usecase "Share Achievement" as UC6
  usecase "Manage User Accounts" as UC7
  usecase "Create Training Plan" as UC8
  usecase "Send Motivational Alert" as UC9
  usecase "Sync Wearable Device" as UC10
  usecase "Connect to Device API" as UC11
  usecase "Parse Sensor Data" as UC12
  usecase "Generate Weekly Report" as UC13
  usecase "Export Data" as UC14
  usecase "Update Profile" as UC15
}

User -- UC1
User -- UC2
User -- UC3
User -- UC4
User -- UC5
User -- UC6
User -- UC10
User -- UC14
User -- UC15

Coach -- UC8
Coach -- UC9
Coach -- UC13

Admin -- UC7

UC10 ..> UC11 : <<include>>
UC10 ..> UC12 : <<include>>

UC14 ..> UC13 : <<extend>>
@enduml