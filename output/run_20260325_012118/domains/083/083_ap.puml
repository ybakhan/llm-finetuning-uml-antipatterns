@startuml
left to right direction

actor "Harbor Master" as HM
actor "Ship Captain" as SC
actor "Crane Operator" as CO
actor "Customs Officer" as CUS
actor "Billing Clerk" as BC

rectangle "Port Management System" {
  usecase "Request Berth Assignment" as UC1
  usecase "Check Berth Availability" as UC2
  usecase "Record Vessel Details" as UC3
  usecase "Approve Vessel Entry" as UC4
  usecase "Manage Cargo Loading" as UC5
  usecase "Verify Cargo Weight" as UC6
  usecase "Operate Crane" as UC7
  usecase "Perform Customs Inspection" as UC8
  usecase "Submit Cargo Declaration" as UC9
  usecase "Generate Port Charges Invoice" as UC10
  usecase "Track Vessel Departure" as UC11
  usecase "Monitor Port Traffic" as UC12
  usecase "Manage Dangerous Goods" as UC13
}

SC -- UC1
UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<include>>
HM -- UC4
HM -- UC12
HM -- UC11
CO -- UC5
UC5 ..> UC6 : <<include>>
CO -- UC7
CUS -- UC8
SC -- UC9
BC -- UC10
HM -- UC13
@enduml