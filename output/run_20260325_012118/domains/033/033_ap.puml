@startuml
left to right direction

actor "Property Seller" as Seller
actor "Property Buyer" as Buyer
actor "Real Estate Agent" as Agent
actor "System Administrator" as Admin

rectangle "Real Estate Listing Platform" {
  usecase "Create Property Listing" as UC1
  usecase "Upload Photos" as UC2
  usecase "Search Properties" as UC3
  usecase "Filter Search Results" as UC4
  usecase "Schedule Property Viewing" as UC5
  usecase "Submit Offer" as UC6
  usecase "Validate Offer Amount" as UC7
  usecase "Manage Agent Profile" as UC8
  usecase "Generate Market Report" as UC9
  usecase "Save Favorite Listings" as UC10
  usecase "Moderate Listings" as UC11
  usecase "Manage User Accounts" as UC12
  usecase "Contact Seller" as UC13
}

Seller -- UC1
UC1 ..> UC2 : <<include>>
Buyer -- UC3
UC3 ..> UC4 : <<include>>
Buyer -- UC5
Buyer -- UC6
UC6 ..> UC7 : <<include>>
Agent -- UC8
Agent -- UC9
Buyer -- UC10
Admin -- UC11
Admin -- UC12
Buyer -- UC13
Agent -- UC5
@enduml