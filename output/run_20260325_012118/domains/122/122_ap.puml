@startuml
left to right direction

actor "Retail Trader" as RT
actor "Institutional Trader" as IT
actor "Compliance Officer" as CO
actor "Market Data Provider" as MDP

rectangle "Stock Trading Platform" {
  usecase "Place Market Order" as UC1
  usecase "Validate Order Parameters" as UC2
  usecase "Check Account Balance" as UC3
  usecase "Place Limit Order" as UC4
  usecase "Verify Price Threshold" as UC5
  usecase "View Portfolio" as UC6
  usecase "Execute Block Trade" as UC7
  usecase "Monitor Compliance" as UC9
  usecase "Generate Audit Report" as UC10
  usecase "Receive Market Feed" as UC11
  usecase "Set Price Alert" as UC12
  usecase "Cancel Order" as UC13
  usecase "View Trade History" as UC14
}

RT -- UC1
RT -- UC4
RT -- UC6
RT -- UC12
RT -- UC13
RT -- UC14
IT -- UC7
IT -- UC6
CO -- UC9
CO -- UC10
MDP -- UC11

UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<include>>
UC4 ..> UC5 : <<include>>
@enduml