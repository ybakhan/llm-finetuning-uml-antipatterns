@startuml
left to right direction

actor "Loan Applicant" as Applicant
actor "Loan Officer" as Officer
actor "Underwriter" as Underwriter
actor "Credit Bureau" as CreditBureau

rectangle "Mortgage Application System" {
  usecase "Submit Mortgage Application" as UC1
  usecase "Collect Personal Details" as UC2
  usecase "Attach Supporting Documents" as UC3
  usecase "Review Application" as UC4
  usecase "Calculate Debt-to-Income Ratio" as UC5
  usecase "Pull Credit Report" as UC6
  usecase "Perform Underwriting" as UC7
  usecase "Evaluate Risk Score" as UC8
  usecase "Approve Mortgage" as UC9
  usecase "Deny Mortgage" as UC10
  usecase "Generate Pre-Approval Letter" as UC11
  usecase "Schedule Closing" as UC12
  usecase "Track Application Status" as UC13
  usecase "Upload Income Verification" as UC14
}

Applicant -- UC1
Applicant -- UC13
Applicant -- UC14
Officer -- UC4
Officer -- UC6
Officer -- UC9
Officer -- UC10
Officer -- UC11
Officer -- UC12
Underwriter -- UC7
CreditBureau -- UC6

UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<include>>
UC4 ..> UC5 : <<include>>
UC7 ..> UC8 : <<include>>

Underwriter -- UC9
Underwriter -- UC10
@enduml