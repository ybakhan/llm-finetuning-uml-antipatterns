@startuml
left to right direction

actor "HR Manager" as HR
actor "Payroll Officer" as PO
actor "Employee" as EMP
actor "Finance Director" as FD
actor "Tax Authority" as TA

rectangle "Payroll Management System" {
  usecase "Manage Employee Records" as UC1
  usecase "Configure Pay Grades" as UC2
  usecase "Process Monthly Payroll" as UC3
  usecase "Generate Payslips" as UC7
  usecase "Submit Tax Filing" as UC8
  usecase "View Payslip" as UC9
  usecase "Request Leave" as UC10
  usecase "Approve Leave" as UC11
  usecase "Generate Payroll Report" as UC12
  usecase "Manage Overtime" as UC13
  usecase "Approve Payroll" as UC14
  usecase "Process Bonus Payment" as UC15
  usecase "View Tax Summary" as UC16
}

HR -- UC1
HR -- UC2
HR -- UC11
HR -- UC13
PO -- UC3
PO -- UC7
PO -- UC8
PO -- UC15
EMP -- UC9
EMP -- UC10
EMP -- UC16
FD -- UC12
FD -- UC14
TA -- UC8
@enduml