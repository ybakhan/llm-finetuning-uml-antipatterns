@startuml
left to right direction

actor "League Administrator" as Admin
actor "Team Manager" as Manager
actor "Referee" as Referee
actor "Fan" as Fan

rectangle "Sports League Management System" {
  usecase "Register Team" as UC1
  usecase "Validate Team Roster" as UC1a
  usecase "Check Registration Fees" as UC1b

  usecase "Schedule Match" as UC2
  usecase "Check Venue Availability" as UC2a

  usecase "Record Match Result" as UC3
  usecase "Update League Standings" as UC4
  usecase "Assign Referee to Match" as UC5
  usecase "Submit Lineup" as UC6
  usecase "View League Standings" as UC7
  usecase "View Match Schedule" as UC8
  usecase "Manage Player Transfers" as UC9
  usecase "Report Disciplinary Action" as UC10
  usecase "Generate Season Report" as UC11
  usecase "Purchase Season Tickets" as UC12
}

Admin -- UC1
UC1 ..> UC1a : <<include>>
UC1 ..> UC1b : <<include>>

Admin -- UC2
UC2 ..> UC2a : <<include>>

Admin -- UC4
Admin -- UC5
Admin -- UC11

Referee -- UC3
Referee -- UC10

Manager -- UC6
Manager -- UC9

Fan -- UC7
Fan -- UC8
Fan -- UC12
@enduml