@startuml
left to right direction

actor "Customer" as Customer
actor "Delivery Driver" as Driver

rectangle "Grocery Delivery Service" {
  usecase "Browse Products" as UC1
  usecase "Place Order" as UC2
  usecase "Validate Payment" as UC3
  usecase "Track Delivery" as UC4
  usecase "Complete Delivery" as UC5
}

Customer -- UC1
Customer -- UC2
UC2 ..> UC3 : <<include>>
Customer -- UC4
Driver -- UC5
@enduml