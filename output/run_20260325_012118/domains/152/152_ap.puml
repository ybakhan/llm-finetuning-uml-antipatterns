@startuml
left to right direction

actor "System Administrator" as Admin
actor "End User" as User
actor "Scheduler" as Scheduler

rectangle "Data Backup and Recovery System" {
  usecase "Configure Backup Policy" as UC1
  usecase "Run Full Backup" as UC2
  usecase "Run Incremental Backup" as UC3
  usecase "Restore Files" as UC4
  usecase "View Backup Logs" as UC5
  usecase "Schedule Automated Backup" as UC6
  usecase "Monitor Storage Capacity" as UC7
  usecase "Request File Recovery" as UC8
  usecase "Verify Backup Integrity" as UC9
  usecase "Compress Backup Data" as UC10
  usecase "Notify Admin on Failure" as UC11
  usecase "Generate Recovery Report" as UC12
  usecase "Locate Backup Snapshot" as UC13
}

Admin -- UC1
Admin -- UC2
Admin -- UC3
Admin -- UC5
Admin -- UC7
Admin -- UC9
Scheduler -- UC6
User -- UC8
User -- UC4

UC2 ..> UC10 : <<include>>
UC4 ..> UC13 : <<include>>
UC6 ..> UC3 : <<include>>
UC11 ..> UC2 : <<extend>>
UC12 ..> UC8 : <<extend>>
@enduml