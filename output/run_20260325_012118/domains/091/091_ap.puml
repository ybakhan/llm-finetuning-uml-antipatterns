@startuml
left to right direction

actor "Citizen" as Citizen
actor "Complaint Officer" as Officer
actor "Administrator" as Admin

rectangle "Public Complaint Management System" {
  usecase "Submit Complaint" as UC1
  usecase "Validate Complaint Form" as UC2
  usecase "Generate Complaint ID" as UC3
  usecase "Track Complaint Status" as UC4
  usecase "Investigate Complaint" as UC5
  usecase "Retrieve Case Files" as UC6
  usecase "Assign Complaint to Officer" as UC7
  usecase "Resolve Complaint" as UC8
  usecase "Provide Feedback" as UC9
  usecase "Generate Reports" as UC10
  usecase "Manage User Accounts" as UC11
  usecase "Escalate Complaint" as UC12
  usecase "View Complaint History" as UC13
}

Citizen -- UC1
Citizen -- UC4
Citizen -- UC9
Officer -- UC5
Officer -- UC8
Officer -- UC12
Officer -- UC13
Admin -- UC7
Admin -- UC10
Admin -- UC11

UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<include>>
UC5 ..> UC6 : <<include>>
@enduml