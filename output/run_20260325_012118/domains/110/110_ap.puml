@startuml
left to right direction

actor "Student" as Student
actor "Instructor" as Instructor
actor "Administrator" as Admin

rectangle "Plagiarism Detection System" {
  usecase "Submit Document" as UC1
  usecase "Parse Document Content" as UC2
  usecase "View Submission History" as UC3
  usecase "Run Plagiarism Check" as UC4
  usecase "Compare Against Database" as UC5
  usecase "Calculate Similarity Score" as UC6
  usecase "Review Similarity Report" as UC7
  usecase "Flag Submission" as UC8
  usecase "Manage Source Database" as UC9
  usecase "Configure Detection Thresholds" as UC10
  usecase "Generate System Analytics" as UC11
  usecase "Appeal Flagged Submission" as UC12
  usecase "Manage User Accounts" as UC13
}

Student -- UC1
UC1 ..> UC2 : <<include>>
Student -- UC3
Instructor -- UC4
UC4 ..> UC5 : <<include>>
UC4 ..> UC6 : <<include>>
Instructor -- UC7
Instructor -- UC8
Admin -- UC9
Admin -- UC10
Admin -- UC11
Student -- UC12
Admin -- UC13
@enduml