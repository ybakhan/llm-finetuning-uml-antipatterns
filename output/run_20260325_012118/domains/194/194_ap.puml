@startuml
left to right direction

actor "Author" as Author
actor "Reader" as Reader

rectangle "Fan Fiction Community" {
  usecase "Publish Story" as UC1
  usecase "Validate Content" as UC2
  usecase "Read Story" as UC3
  usecase "Leave Review" as UC4
}

Author -- UC1
UC1 ..> UC2 : <<include>>
Reader -- UC3
Reader -- UC4
@enduml