@startuml
left to right direction

actor Photographer as P
actor Viewer as V
actor Administrator as A

rectangle "Digital Photography Platform" {
  usecase "Upload Photo" as UC1
  usecase "Validate File Format" as UC2
  usecase "Generate Thumbnail" as UC3
  usecase "Browse Gallery" as UC4
  usecase "Search Photos" as UC5
  usecase "Parse Search Query" as UC6
  usecase "Download Photo" as UC7
  usecase "Rate Photo" as UC8
  usecase "Comment on Photo" as UC9
  usecase "Create Album" as UC10
  usecase "Moderate Content" as UC11
  usecase "Manage User Accounts" as UC12
  usecase "View Photo Details" as UC13
}

P -- UC1
P -- UC10
P -- UC4
P -- UC13
V -- UC4
V -- UC5
V -- UC7
V -- UC8
V -- UC9
V -- UC13
A -- UC11
A -- UC12

UC1 ..> UC2 : <<include>>
UC1 ..> UC3 : <<include>>
UC5 ..> UC6 : <<include>>
UC4 ..> UC13 : <<include>>
}
@enduml