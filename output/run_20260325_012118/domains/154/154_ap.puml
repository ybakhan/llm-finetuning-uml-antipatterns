@startuml
left to right direction

actor "End User" as EU
actor "IT Administrator" as Admin
actor "Security Officer" as SO

rectangle "Remote Desktop Service" {
  usecase "Initiate Remote Session" as UC1
  usecase "Authenticate User" as UC2
  usecase "Verify Credentials" as UC3
  usecase "Manage Virtual Machines" as UC4
  usecase "Allocate VM Resources" as UC5
  usecase "Transfer Files" as UC6
  usecase "Encrypt File Data" as UC7
  usecase "Monitor Active Sessions" as UC8
  usecase "Terminate Session" as UC9
  usecase "Configure Access Policies" as UC10
  usecase "View Session Logs" as UC11
  usecase "Adjust Display Settings" as UC12
}

EU -- UC1
EU -- UC6
EU -- UC12
EU -- UC9
Admin -- UC4
Admin -- UC8
Admin -- UC9
SO -- UC10
SO -- UC11

UC1 ..> UC2 : <<include>>
UC2 ..> UC3 : <<include>>
UC4 ..> UC5 : <<include>>
UC6 ..> UC7 : <<include>>
@enduml