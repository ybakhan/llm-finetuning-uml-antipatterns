@startuml
left to right direction

actor "Sales Rep" as A1
actor "Marketing Manager" as A2
actor "Support Agent" as A3
actor "CRM Administrator" as A4

rectangle "Customer Relationship Management System" {
  usecase "Manage Contacts" as UC1
  usecase "Validate Contact Fields" as UC2
  usecase "Log Interaction" as UC3
  usecase "Create Sales Opportunity" as UC4
  usecase "Generate Pipeline Report" as UC5
  usecase "Launch Email Campaign" as UC6
  usecase "Compose Email Template" as UC7
  usecase "Track Campaign Metrics" as UC8
  usecase "Handle Support Ticket" as UC9
  usecase "Categorize Ticket Priority" as UC10
  usecase "Configure User Roles" as UC11
  usecase "Import Customer Data" as UC12
}

A1 -- UC1
UC1 ..> UC2 : <<include>>
A1 -- UC3
A1 -- UC4
A1 -- UC5
A2 -- UC6
UC6 ..> UC7 : <<include>>
A2 -- UC8
A3 -- UC9
UC9 ..> UC10 : <<include>>
A4 -- UC11
A4 -- UC12
@enduml