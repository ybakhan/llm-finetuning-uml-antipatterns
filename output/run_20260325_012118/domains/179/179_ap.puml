@startuml
left to right direction

actor "Environmental Officer" as EO
actor "Technician" as Tech

rectangle "Air Quality Monitoring System" {
  usecase "View Air Quality Report" as UC1
  usecase "Configure Sensor" as UC2
  usecase "Set Alert Thresholds" as UC3
  usecase "Receive Pollution Alert" as UC4
  usecase "Generate Report" as UC5
  usecase "Fetch Sensor Data" as UC6
  usecase "Format Report Output" as UC7
}

EO -- UC1
EO -- UC3
EO -- UC4
Tech -- UC2
EO -- UC5
UC5 .> UC6 : <<include>>
UC5 .> UC7 : <<include>>
@enduml